# ══════════════════════════════════════════════════════════════════════════════
# TradeRecon AI Agent — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file:  copy .env.example .env      (Windows)
#                       cp .env.example .env         (Mac/Linux)
#   2. Fill in your values below
#   3. NEVER commit .env to Git — it is in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Claude Model Selection ────────────────────────────────────────────────────
# claude-haiku-4-5-20251001   ← cheapest, fastest (recommended for dev)
# claude-sonnet-4-6           ← smarter, slightly more expensive
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Email Configuration (Gmail SMTP) ─────────────────────────────────────────
# Use a Gmail App Password (NOT your real password)
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_SENDER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Safety Mode ───────────────────────────────────────────────────────────────
# Set to true during development — logs emails instead of sending them
EMAIL_DRY_RUN=true

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# Environment: development | staging | production
ENVIRONMENT=development

# Enable verbose debug logging
DEBUG=true

# ── Data Paths (override config/settings.yaml if needed) ─────────────────────
# DATA_SOURCE_A=data/samples/source_a_trades.csv
# DATA_SOURCE_B=data/samples/source_b_trades.csv
